---
permalink: feed.xml
layout: false
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.author }}</title>
  <subtitle>Notes on distributed systems &amp; engineering.</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}/" rel="alternate" type="text/html"/>
  <updated>{% if collections.postsSorted | length %}{{ collections.postsSorted[0].date | dateIso }}{% else %}{% nowIso %}{% endif %}</updated>
  <id>{{ site.url }}/</id>
  <author><name>{{ site.author }}</name></author>
  {% for post in collections.postsSorted %}
  <entry>
    <title>{{ post.data.title | e }}</title>
    <link href="{{ site.url }}{{ post.url }}" rel="alternate" type="text/html"/>
    <id>{{ site.url }}{{ post.url }}</id>
    <updated>{{ post.date | dateIso }}</updated>
    {% if post.data.description %}
    <summary type="text">{{ post.data.description | e }}</summary>
    {% endif %}
  </entry>
  {% endfor %}
</feed>
