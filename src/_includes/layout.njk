<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="{{ description | default(site.description) }}"
    />
    <title>
      {%- if title and page.url != "/" -%}
        {{ title }} · Divya Swaminathan
      {%- else -%}
        Divya Swaminathan
      {%- endif -%}
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;1,9..144,400&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ page.url | rootRel }}styles.css" />
    <link
      rel="alternate"
      type="application/atom+xml"
      title="{{ site.author }}"
      href="{{ page.url | rootRel }}feed.xml"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="logo" href="{{ page.url | rootRel }}index.html">DS</a>
        <nav class="nav" aria-label="Primary">
          <a href="{{ page.url | rootRel }}blog/">Blog</a>
          <a href="{{ page.url | rootRel }}#about">About</a>
          <a href="{{ page.url | rootRel }}#work">Work</a>
          <a href="{{ page.url | rootRel }}#principles">Principles</a>
          <a href="{{ page.url | rootRel }}#writing">Writing</a>
          <a href="{{ page.url | rootRel }}#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main id="main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <p>© <span id="year"></span> Divya Swaminathan</p>
      </div>
    </footer>

    <script>
      document.getElementById("year").textContent = new Date().getFullYear();
    </script>
  </body>
</html>
